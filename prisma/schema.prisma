generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  name            String?
  role            String          @default("owner")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company?
  sessions        Session[]
  managedClients  CompanyAccess[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id             String          @id @default(cuid())
  userId         String          @unique
  name           String
  taxNumber      String
  taxOffice      String?
  companyType    String          @default("sole_proprietorship")
  vatPeriod      String          @default("monthly")
  providerName   String?
  providerConfig String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  taxSummaries   TaxSummary[]
  accountants    CompanyAccess[]
}

model CompanyAccess {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Invoice {
  id                String                 @id @default(cuid())
  companyId         String
  providerName      String?
  invoiceDirection  String
  invoiceType       String                 @default("eInvoice")
  invoiceNumber     String?
  ettn              String?
  invoiceDate       DateTime
  supplierName      String?
  supplierTaxNumber String?
  customerName      String?
  customerTaxNumber String?
  currency          String                 @default("TRY")
  netAmount         Float                  @default(0)
  vatAmount         Float                  @default(0)
  grossAmount       Float                  @default(0)
  status            String                 @default("active")
  xmlUrl            String?
  pdfUrl            String?
  rawXml            String?
  rawJson           String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  company           Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines             InvoiceLine[]
  classification    ExpenseClassification?
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  description String?
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  vatRate     Float   @default(18)
  netAmount   Float   @default(0)
  vatAmount   Float   @default(0)
  grossAmount Float   @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ExpenseClassification {
  id                      String   @id @default(cuid())
  invoiceId               String   @unique
  category                String?
  classification          String
  confidenceScore         Float    @default(0)
  reason                  String?
  accountantNote          String?
  accountantFinalDecision String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  invoice                 Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model TaxSummary {
  id                       String   @id @default(cuid())
  companyId                String
  periodType               String
  startDate                DateTime
  endDate                  DateTime
  outgoingNetTotal         Float    @default(0)
  outgoingVatTotal         Float    @default(0)
  incomingNetTotal         Float    @default(0)
  deductibleVatTotal       Float    @default(0)
  nonDeductibleVatTotal    Float    @default(0)
  estimatedPayableVat      Float    @default(0)
  estimatedCarryForwardVat Float    @default(0)
  estimatedProfit          Float    @default(0)
  estimatedProvisionalTax  Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  company                  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id          String   @id @default(cuid())
  year        Int
  companyType String
  rateType    String
  rate        Float
  description String?
  createdAt   DateTime @default(now())
}
